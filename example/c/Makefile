PROJECT_NAME = example_module

BUILD_DIR = build
SRC_DIR = src
INCLUDE_DIR = include
CONFIG_DIR = config

CONFIG_H = $(INCLUDE_DIR)/generated/config.h

CC = gcc
CFLAGS = -I$(INCLUDE_DIR) -I$(INCLUDE_DIR)/generated -Wall -Wextra -O2

TARGET = $(BUILD_DIR)/$(PROJECT_NAME)

SRCS := $(shell find $(SRC_DIR) -name "*.c" -o -name "*.cpp")

all: prepare config config_header build

prepare:
	@mkdir -p $(BUILD_DIR)
	@mkdir -p $(INCLUDE_DIR)/generated

config: prepare
	@if [ -f .config ]; then \
		mv .config $(BUILD_DIR)/.config; \
		echo "[INFO] Using existing .config"; \
	else \
		echo "[INFO] No .config found, loading defconfig"; \
		cp $(CONFIG_DIR)/defconfig $(BUILD_DIR)/.config; \
	fi

menuconfig:
	@echo "[INFO] Opening menuconfig..."
	@menuconfig $(KCONFIG_FILE)

config_header: config
	@echo "[INFO] Generating config header..."
	@echo "/* Generated by Makefile - DO NOT EDIT */" > $(CONFIG_H)
	@echo "#pragma once" >> $(CONFIG_H)
	@echo "" >> $(CONFIG_H)
	@if [ -f $(BUILD_DIR)/.config ]; then \
		while IFS= read -r line || [ -n "$$line" ]; do \
			case "$$line" in \
				"") continue ;; \
				"#"*) continue ;; \
				*=* ) \
					key=$${line%%=*}; \
					val=$${line#*=}; \
					if [ "$$val" = "y" ]; then \
						echo "#define $$key 1" >> $(CONFIG_H); \
					else \
						echo "#define $$key $$val" >> $(CONFIG_H); \
					fi ;; \
			esac; \
		done < $(BUILD_DIR)/.config; \
		echo "[INFO] $(CONFIG_H) successfully generated."; \
	else \
		echo "[ERROR] .config file not found in $(BUILD_DIR)!"; \
		exit 1; \
	fi
	
build:
	@echo "[INFO] Building project..."
	@$(CC) $(CFLAGS) $(SRCS) -o $(TARGET)

clean:
	rm -rf $(BUILD_DIR)
	rm -rf $(INCLUDE_DIR)/generated

.PHONY: all prepare config menuconfig config_header build clean